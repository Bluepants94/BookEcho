# BookEcho 本地 / Docker 环境变量示例
# 复制为 .env 后按需修改：cp .env.example .env

# JWT 签名密钥（务必改为足够长的随机串）
# docker-compose 会同时注入为 JWT_SECRET 与 SECRET_KEY（兼容 backend Settings.secret_key）
# 同时用于用户 TTS API Key 的服务端加密派生
JWT_SECRET=change-me-to-a-long-random-secret

# 首次启动时引导创建的管理员账号
BOOTSTRAP_ADMIN_USERNAME=admin
BOOTSTRAP_ADMIN_PASSWORD=admin123

# SQLite 数据库路径（容器内路径；通过 volume 持久化到 /data）
DATABASE_URL=sqlite:////data/bookecho.db

# 用户书籍等文件存储根目录（相对工作目录或绝对路径；Docker 下通常与 /data 一致）
DATA_DIR=/data

# 允许的前端来源（逗号分隔）
CORS_ORIGINS=http://localhost:25698,http://127.0.0.1:25698,http://localhost,http://127.0.0.1

# 是否允许 TTS 代理访问私网 / 本机地址（默认 false）
# 仅在调试内网 TTS 服务时改为 true；生产环境请保持 false
TTS_ALLOW_PRIVATE_URLS=false

# 说明：
# - 不要在此处配置任何 TTS / 语音合成 API Key
# - TTS Key 由用户在前端设置页提交；服务端加密写入 users.tts_settings_json
# - 读取接口返回脱敏 Key；浏览器本地缓存完整 Key 供播放时按次代理使用
# - 后端仅在请求生命周期内内存转发 TTS，不缓存合成音频
